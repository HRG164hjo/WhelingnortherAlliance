  <!-- EN: bad dream -->
  <WNA_FacingVoid.stages.bad_dream.label>坏梦</WNA_FacingVoid.stages.bad_dream.label>
  <!-- EN: everything i can feel is black or empty, is this a nightmare? -->
  <WNA_FacingVoid.stages.bad_dream.description>我能感觉到的只有黑暗和虚无，这是噩梦吗？</WNA_FacingVoid.stages.bad_dream.description>
  <!-- EN: it's dark here -->
  <WNA_FacingVoid.stages.its_dark_here.label>这里有点黑</WNA_FacingVoid.stages.its_dark_here.label>
  <!-- EN: everything i can feel is black or empty, is this a nightmare? -->
  <WNA_FacingVoid.stages.its_dark_here.description>我能感觉到的只有黑暗和虚无，这是噩梦吗？</WNA_FacingVoid.stages.its_dark_here.description>
