<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="WNA_ItemsBase">
        <defName>WNA_Ration</defName>
        <label>WNA military ration</label>
        <description>Standard ration pack for Whelingnorther Military, produced from highest quality materials - theoretically. Anything that contains nutrients can be used to make this ration if needed.</description>
        <graphicData>
            <texPath>item/wna_ration</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
            <drawSize>0.85</drawSize>
            <color>(255,255,255,250)</color>
        </graphicData>
        <statBases>
            <MarketValue>20</MarketValue>
            <Nutrition>2</Nutrition>
        </statBases>
        <socialPropernessMatters>true</socialPropernessMatters>
        <ingestible>
            <foodType>Meal</foodType>
            <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
            <optimalityOffsetHumanlikes>10</optimalityOffsetHumanlikes>
            <optimalityOffsetFeedingAnimals>-10</optimalityOffsetFeedingAnimals>
            <preferability>MealLavish</preferability>
            <tasteThought>WNA_AteMealPack</tasteThought>
            <ingestEffect>EatVegetarian</ingestEffect>
            <ingestSound>Meal_Eat</ingestSound>
            <babiesCanIngest>true</babiesCanIngest>
            <outcomeDoers>
                <li Class="IngestionOutcomeDoer_OffsetHemogen">
                    <offset>2.0</offset>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetPsyfocus">
                    <offset>20.0</offset>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Mood</need>
                    <offset>2.0</offset>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Rest</need>
                    <offset>2.0</offset>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Joy</need>
                    <offset>2.0</offset>
                </li>
                <li Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Comfort</need>
                    <offset>2.0</offset>
                </li>
                <li MayRequire="ludeon.rimworld.biotech" Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Deathrest</need>
                    <offset>2.0</offset>
                </li>
                <li MayRequire="ludeon.rimworld.biotech" Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Play</need>
                    <offset>2.0</offset>
                </li>
                <li MayRequire="ludeon.rimworld.odyssey" Class="IngestionOutcomeDoer_Psilocap">
                    <chanceBreakdown>0</chanceBreakdown>
                    <chanceInspiration>0.01</chanceInspiration>
                </li>
                <li MayRequire="Aelanna.BetterPyromania" Class="IngestionOutcomeDoer_OffsetNeed">
                    <need>Fire</need>
                    <offset>2.0</offset>
                </li>
            </outcomeDoers>
        </ingestible>
        <thingCategories>
            <li>FoodMeals</li>
        </thingCategories>
    </ThingDef>

    <ThingDef ParentName="WNA_ItemsBase">
        <defName>WNA_Medikit</defName>
        <label>WNA military medikit</label>
        <description>Medicines and tools packed together in WNA standard, processed from various possible materials.</description>
        <thingClass>Medicine</thingClass>
        <graphicData>
            <texPath>item/wna_medikit</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
            <drawSize>0.75</drawSize>
            <color>(255,255,255,250)</color>
        </graphicData>
        <statBases>
            <MarketValue>30</MarketValue>
            <MedicalPotency>255</MedicalPotency>
            <MedicalQualityMax>999999</MedicalQualityMax>
        </statBases>
        <comps>
            <li Class="CompProperties_Usable">
                <useJob>UseItem</useJob>
                <useLabel>Use {0_label}</useLabel>
                <useDuration>0</useDuration>
                <warmupMote>Mote_ResurrectAbility</warmupMote>
                <showUseGizmo>true</showUseGizmo>
            </li>
            <li Class="CompProperties_Targetable">
                <compClass>CompTargetable_SingleCorpse</compClass>
                <fleshCorpsesOnly>true</fleshCorpsesOnly>
                <nonDessicatedCorpsesOnly>false</nonDessicatedCorpsesOnly>
            </li>
            <li Class="CompProperties_TargetEffectResurrect">
                <moteDef>Mote_ResurrectFlash</moteDef>
                <withSideEffects>false</withSideEffects>
                <addsHediff MayRequire="ludeon.rimworld.anomaly">DeathRefusalCreepJoiner</addsHediff>
            </li>
            <li MayRequire="xmb.ancienturbanruins.mo" Class="AncientMarket_Libraray.CompPropertiesUseableCount">
                <useableCount>24</useableCount>
            </li>
        </comps>
        <thingCategories>
            <li>Medicine</li>
        </thingCategories>
        <orderedTakeGroup>Medicine</orderedTakeGroup>
    </ThingDef>
    
    <ThingDef ParentName="WNA_ItemsBase">
        <defName>WNA_FactionDeed</defName>
        <label>faction recruitment deed</label>
        <description>A deed that allows you to spend some goodwill to recruit a soldier from WNA to serve you, you must be &lt;color=#00FF00&gt;allied&lt;/color&gt; with WNA to use this.</description>
        <tickerType>Rare</tickerType>
        <graphicData>
            <texPath>item/wna_deed</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>0.8</drawSize>
        </graphicData>
        <statBases>
            <MarketValue>2357</MarketValue>
        </statBases>
        <comps>
            <li Class="WNA.ThingCompProp.PropFactionDeed">
                <useLabel>Use {0_label}</useLabel>
                <useJob>WNA_Job_UseDeedOn</useJob>
                <useDuration>0</useDuration>
                <showUseGizmo>true</showUseGizmo>
                <targetFactionDef>WNA_FactionWNA</targetFactionDef>
            </li>
            <li Class="WNA.ThingCompProp.PropFactionDeed_TargetPawn">
                <compClass>WNA.ThingCompProp.CompFactionDeed_TargetPawn</compClass>
                <ignorePlayerFactionPawns>true</ignorePlayerFactionPawns>
                <targetFactionDef>WNA_FactionWNA</targetFactionDef>
            </li>
            <li Class="WNA.ThingCompProp.PropFactionDeed_HostileDestruct">
                <targetFactionDef>WNA_FactionWNA</targetFactionDef>
            </li>
        </comps>
    </ThingDef>
</Defs>