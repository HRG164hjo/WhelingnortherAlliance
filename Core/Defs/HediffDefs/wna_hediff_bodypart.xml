        </fixedIngredientFilter>
        <appliedOnFixedBodyParts>
            <li>Torso</li>
        </appliedOnFixedBodyParts>
        <addsHediff>WNA_Part_AdvBionicSkin</addsHediff>
    </RecipeDef>
    
