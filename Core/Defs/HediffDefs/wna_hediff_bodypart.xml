    <ThingDef ParentName="WNA_BodypartItem">
        <defName>WNA_Part_AdvBionicSkin</defName>
        <label>adv. bionic skin</label>
        <description>A bionic skin implant made with advanced technologies. Due to how this implant is designed and how it works, installing it is a one-way trip. \n\n&lt;color=#VC86400&gt;Rad proof.&lt;/color&gt;</description>
        <statBases>
            <MarketValue>1440</MarketValue>
        </statBases>
        <costList>
            <Plasteel>15</Plasteel>
            <ComponentIndustrial>4</ComponentIndustrial>
            <WNA_AttunementFabric>25</WNA_AttunementFabric>
            <BroadshieldCore MayRequire="Ludeon.Rimworld.Royalty">1</BroadshieldCore>
        </costList>
    </ThingDef>
    <HediffDef ParentName="WNA_BodypartHediff">
        <defName>WNA_Part_AdvBionicSkin</defName>
        <label>adv. bionic skin</label>
        <description>An installed adv bionic skin. \n\n&lt;color=#VC86400&gt;Rad proof.&lt;/color&gt;</description>
        <hediffClass>HediffWithComps</hediffClass>
        <stages>
            <li>
                <partIgnoreMissingHP>true</partIgnoreMissingHP>
                <statOffsets>
                    <VacuumResistance>0.8</VacuumResistance>
                    <ComfyTemperatureMin>-20</ComfyTemperatureMin>
                    <ComfyTemperatureMax>20</ComfyTemperatureMax>
                    <PawnBeauty>1</PawnBeauty>
                    <ArmorRating_Sharp>2</ArmorRating_Sharp>
                    <ArmorRating_Blunt>2</ArmorRating_Blunt>
                    <ArmorRating_Heat>2</ArmorRating_Heat>
                </statOffsets>
				<statFactors>
                    <Flammability>0</Flammability>
					<IncomingDamageFactor MayRequire="Ludeon.Rimworld.Royalty">0</IncomingDamageFactor>
				</statFactors>
                <preventVacuumBurns>true</preventVacuumBurns>
            </li>
        </stages>
		<modExtensions>
            <li Class="WNA.DMExtension.TechnoConfig">
                <immuneToRadiation>true</immuneToRadiation>
            </li>
		</modExtensions>
    </HediffDef>
    <RecipeDef ParentName="WNA_BodypartRecipe">
        <defName>WNA_Part_AdvBionicSkin</defName>
        <label>install adv. bionic skin</label>
        <description>install adv bionic skin.</description>
        <workerClass>Recipe_InstallImplant</workerClass>
        <jobString>Installing adv bionic skin.</jobString>
        <ingredients>
