<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <TraderKindDef ParentName="WNA_TraderKindBase">
        <defName>WNA_Trader_Settlement</defName>
        <label>whelingnorther branch storage</label>
        <stockGenerators>
            <li Class="StockGenerator_Animals">
                <tradeTagsSell>
                    <li>AnimalCommon</li>
                    <li>AnimalDryad</li>
                    <li>AnimalExotic</li>
                    <li>AnimalFarm</li>
                    <li>AnimalFighter</li>
                    <li>AnimalInsect</li>
                    <li>AnimalPet</li>
                    <li>AnimalUncommon</li>
                    <li>WNATradeTag_Animal</li>
                </tradeTagsSell>
                <tradeTagsBuy>
                    <li>AnimalCommon</li>
                    <li>AnimalDryad</li>
                    <li>AnimalExotic</li>
                    <li>AnimalFarm</li>
                    <li>AnimalFighter</li>
                    <li>AnimalInsect</li>
                    <li>AnimalPet</li>
                    <li>AnimalUncommon</li>
                    <li>WNATradeTag_Animal</li>
                </tradeTagsBuy>
                <kindCountRange>2~3</kindCountRange>
                <countRange>8~10</countRange>
            </li>
            <li Class="StockGenerator_Techprints">
                <countChances>
                    <li>
                        <count>5</count>
                        <chance>1</chance>
                    </li>
                </countChances>
            </li>
        </stockGenerators>
    </TraderKindDef>

    <TraderKindDef ParentName="WNA_TraderKindBase">
        <defName>WNA_Trader_Orbital</defName>
        <label>whelingnorther orbital storage</label>
        <orbital>true</orbital>
        <commonality>1</commonality>
        <stockGenerators>
            <li Class="StockGenerator_Techprints">
                <countChances>
                    <li>
                        <count>10</count>
                        <chance>1</chance>
                    </li>
                </countChances>
            </li>
            <li Class="StockGenerator_Category">
                <categoryDef>FoodMeals</categoryDef>
                <thingDefCountRange>5~7</thingDefCountRange>
                <countRange>30000000~50000000</countRange>
                <price>VeryCheap</price>
            </li>
        </stockGenerators>
    </TraderKindDef>
    
    <TraderKindDef ParentName="WNA_TraderKindBase">
        <defName>WNA_Trader_Scavenger</defName>
        <label>whelingnorther orbital scavenger</label>
        <orbital>true</orbital>
        <commonality>1</commonality>
        <stockGenerators Inherit="false">
            <li Class="WNA.WNAMiscs.StockGenerator_BuyAnything"/>
            <li Class="StockGenerator_SingleDef">
                <thingDef>Silver</thingDef>
                <countRange>2000000000~2147483647</countRange>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>Gold</thingDef>
                <countRange>2000000000~2147483647</countRange>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>WNA_Ration</thingDef>
                <price>VeryCheap</price>
                <countRange>80000000~100000000</countRange>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>WNA_Medikit</thingDef>
                <price>VeryCheap</price>
                <countRange>80000000~100000000</countRange>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>WNA_FactionDeed</thingDef>
                <price>VeryCheap</price>
                <countRange>23572357~23572357</countRange>
            </li>
            <li Class="StockGenerator_Category">
                <categoryDef>Chunks</categoryDef>
                <thingDefCountRange>30~36</thingDefCountRange>
                <countRange>2000000000~2147483647</countRange>
                <price>VeryCheap</price>
            </li>
            <li Class="StockGenerator_Category" MayRequire="ludeon.rimworld.odyssey">
                <categoryDef>Fish</categoryDef>
                <thingDefCountRange>12~15</thingDefCountRange>
                <countRange>2000000000~2147483647</countRange>
                <price>VeryCheap</price>
            </li>
            <li Class="StockGenerator_SingleDef">
                <thingDef>Skull</thingDef>
                <price>VeryCheap</price>
                <countRange>2000000000~2147483647</countRange>
            </li>
        </stockGenerators>
    </TraderKindDef>

</Defs>
